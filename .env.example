# Copy to .env and fill in. Dev-login works without any OAuth credentials.
DATABASE_URL=postgres://rustcraft:rustcraft@localhost:5433/rustcraft

# Base URL the browser uses to reach the server (OAuth callbacks)
PUBLIC_ORIGIN=http://localhost:3000

# Discord OAuth — https://discord.com/developers/applications
# Redirect URL to register: http://localhost:3000/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URL to register: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
